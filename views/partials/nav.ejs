<div >

    <div class="navContainer">
      <a href="/">Home</a>
    <% if (!locals.currentUser) {%>
    <a href="/auth/sign-up">Sign up</a>
    <a href="/auth/log-in">Log in</a>
  <% }%>
  <% if (locals.currentUser) {%>
    <% if (!locals.currentUser.isadmin && !locals.currentUser.membership_status) {%>
        <a href="/auth/join-club">Join the club</a>
      <% }%>
    
    <a href="/message/new">Create a message</a>
    <a href="/auth/log-out">Log out</a>

  <% }%>
    </div>
    
  <div class="statusDisplay">
      <% if (locals.currentUser) {%>
        <h3>Hello, <%= locals.currentUser.username %>!</h3>

        <% if (locals.currentUser.membership_status && !locals.currentUser.isadmin) {%>
          <h3>Status: Member</h3>
        <% }%>

        <% if (locals.currentUser.isadmin) {%>
          <h3>Status: Admin</h3>
        <% }%>
      <% }%>
  </div>
  
    
</div>